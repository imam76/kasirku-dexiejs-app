{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "frayukti",
  "version": "1.0.38",
  "identifier": "com.asepimamnawawi-imam76.frayukti-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "frayukti",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/f.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postRemoveScript": "linux/postremove.sh"
      },
      "rpm": {
        "postRemoveScript": "linux/postremove.sh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCN0JEN0FFMzBEMkY4REYKUldUZitOSXdydGQ3dXprWFBhUHc5SUxVZHkzQTUvNDd3Z1lmZkl6Z1UvR0diVEVEVURTSW13RTkK",
      "endpoints": [
        "https://github.com/imam76/kasirku-dexiejs-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
