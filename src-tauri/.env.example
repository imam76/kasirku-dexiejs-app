# Desktop/dev runtime.
# For LAN testing, replace localhost with the PostgreSQL host IP.
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/appdb

# Shopee Open Platform (hanya dibaca backend Rust).
SHOPEE_PARTNER_ID=123456
SHOPEE_PARTNER_KEY=replace-with-partner-key
SHOPEE_ENVIRONMENT=sandbox
# Base64 dari tepat 32 byte. Contoh membuat key: openssl rand -base64 32
SHOPEE_TOKEN_ENCRYPTION_KEY=replace-with-base64-32-byte-key
SHOPEE_REDIRECT_URI=http://127.0.0.1:17654/marketplace/shopee/callback

# Android APK cannot read this repo-local .env file on the device.
# For direct LAN testing, pass the database URL during the Android build:
# KASIRKU_DATABASE_URL=postgresql://appuser:apppassword@192.168.1.8:5432/appdb bunx tauri android build
